{
  "manifest_version": 3,
  "name": "Page Navigator",
  "version": "1.2",
  "description": "Navigate between pages using left/right arrow keys",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "patterns.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "options_page": "options.html"
}
